<?xml version="1.0" encoding="UTF-8"?>
<Scheme
   LastUpgradeVersion = "2640"
   version = "1.7">
   <BuildAction
      parallelizeBuildables = "YES"
      buildImplicitDependencies = "YES"
      buildArchitectures = "Automatic">
      <BuildActionEntries>
         <BuildActionEntry
            buildForTesting = "YES"
            buildForRunning = "YES"
            buildForProfiling = "NO"
            buildForArchiving = "NO"
            buildForAnalyzing = "NO">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "CAFE000000000000000001AA"
               BuildableName = "SFTransitWatch Watch App.app"
               BlueprintName = "SFTransitWatch Watch App"
               ReferencedContainer = "container:SFTransitWatch.xcodeproj">
            </BuildableReference>
         </BuildActionEntry>
         <BuildActionEntry
            buildForTesting = "YES"
            buildForRunning = "NO"
            buildForProfiling = "NO"
            buildForArchiving = "NO"
            buildForAnalyzing = "NO">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "CAFE000000000000000020E0"
               BuildableName = "SFTransitWatch.app"
               BlueprintName = "SFTransitWatch"
               ReferencedContainer = "container:SFTransitWatch.xcodeproj">
            </BuildableReference>
         </BuildActionEntry>
      </BuildActionEntries>
   </BuildAction>
   <TestAction
      buildConfiguration = "Debug"
      selectedDebuggerIdentifier = "Xcode.DebuggerFoundation.Debugger.LLDB"
      selectedLauncherIdentifier = "Xcode.DebuggerFoundation.Launcher.LLDB"
      shouldUseLaunchSchemeArgsEnv = "YES"
      shouldAutocreateTestPlan = "YES">
      <PreActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Reset watch sim before tests"
               scriptText = "# Pre-test sim reset for watchOS snapshot scheme.&#10;#&#10;# &quot;Unknown application display identifier&quot; is caused by a stale xctrunner&#10;# install registry on the simulator (or its clone). Parallelizable is disabled&#10;# on this scheme so xcodebuild uses the original sim directly — no clone is&#10;# created — and erasing that sim here is sufficient.&#10;#&#10;# We also delete any lingering clones from previous parallel runs so they&#10;# cannot be re-used accidentally.&#10;#&#10;# NOTE: DerivedData is NOT wiped here (xcodebuild already opened paths inside&#10;# it before this pre-action fires). If the error persists, run&#10;# bin/run-watch-snapshot-tests.sh which wipes DerivedData first.&#10;#&#10;# Logs: /tmp/sftransit-preaction.log&#10;LOG=/tmp/sftransit-preaction.log&#10;echo &quot;[$(date)] sftransit snapshot pre-action firing&quot; &gt;&gt; &quot;$LOG&quot;&#10;&#10;/usr/bin/xcrun simctl shutdown all &gt;&gt; &quot;$LOG&quot; 2&gt;&amp;1 || true&#10;&#10;# Erase the target sim.&#10;/usr/bin/xcrun simctl erase &quot;Apple Watch SE 3 (44mm)&quot; &gt;&gt; &quot;$LOG&quot; 2&gt;&amp;1 || true&#10;&#10;# Delete any clones left over from previous parallelized runs.&#10;/usr/bin/xcrun simctl list devices | grep &quot;Clone.*Apple Watch&quot; \&#10;    | sed &apos;s/.*(\([A-F0-9-]*\)).*/\1/&apos; \&#10;    | while read -r UDID; do&#10;        echo &quot;Deleting clone $UDID&quot; &gt;&gt; &quot;$LOG&quot;&#10;        /usr/bin/xcrun simctl delete &quot;$UDID&quot; &gt;&gt; &quot;$LOG&quot; 2&gt;&amp;1 || true&#10;    done&#10;&#10;echo &quot;[$(date)] sftransit snapshot pre-action done&quot; &gt;&gt; &quot;$LOG&quot;&#10;exit 0&#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "CAFE000000000000000001AA"
                     BuildableName = "SFTransitWatch Watch App.app"
                     BlueprintName = "SFTransitWatch Watch App"
                     ReferencedContainer = "container:SFTransitWatch.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PreActions>
      <Testables>
         <TestableReference
            skipped = "NO"
            parallelizable = "NO">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "84E0253D2FAD714C006B3F47"
               BuildableName = "SFTransitWatchUITests.xctest"
               BlueprintName = "SFTransitWatchUITests"
               ReferencedContainer = "container:SFTransitWatch.xcodeproj">
            </BuildableReference>
         </TestableReference>
      </Testables>
   </TestAction>
   <LaunchAction
      buildConfiguration = "Debug"
      selectedDebuggerIdentifier = "Xcode.DebuggerFoundation.Debugger.LLDB"
      selectedLauncherIdentifier = "Xcode.DebuggerFoundation.Launcher.LLDB"
      launchStyle = "0"
      useCustomWorkingDirectory = "NO"
      ignoresPersistentStateOnLaunch = "NO"
      debugDocumentVersioning = "YES"
      debugServiceExtension = "internal"
      allowLocationSimulation = "YES"
      queueDebuggingEnableBacktraceRecording = "Yes">
      <BuildableProductRunnable
         runnableDebuggingMode = "0">
         <BuildableReference
            BuildableIdentifier = "primary"
            BlueprintIdentifier = "CAFE000000000000000001AA"
            BuildableName = "SFTransitWatch Watch App.app"
            BlueprintName = "SFTransitWatch Watch App"
            ReferencedContainer = "container:SFTransitWatch.xcodeproj">
         </BuildableReference>
      </BuildableProductRunnable>
   </LaunchAction>
   <ProfileAction
      buildConfiguration = "Release"
      shouldUseLaunchSchemeArgsEnv = "YES"
      savedToolIdentifier = ""
      useCustomWorkingDirectory = "NO"
      debugDocumentVersioning = "YES">
      <BuildableProductRunnable
         runnableDebuggingMode = "0">
         <BuildableReference
            BuildableIdentifier = "primary"
            BlueprintIdentifier = "CAFE000000000000000001AA"
            BuildableName = "SFTransitWatch Watch App.app"
            BlueprintName = "SFTransitWatch Watch App"
            ReferencedContainer = "container:SFTransitWatch.xcodeproj">
         </BuildableReference>
      </BuildableProductRunnable>
   </ProfileAction>
   <AnalyzeAction
      buildConfiguration = "Debug">
   </AnalyzeAction>
   <ArchiveAction
      buildConfiguration = "Release"
      revealArchiveInOrganizer = "YES">
   </ArchiveAction>
</Scheme>
