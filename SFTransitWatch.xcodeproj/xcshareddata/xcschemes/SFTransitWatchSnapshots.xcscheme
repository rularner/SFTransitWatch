   version = "1.7">
   <BuildAction
      parallelizeBuildables = "YES"
      buildImplicitDependencies = "YES"
      buildArchitectures = "Automatic">
      <BuildActionEntries>
         <BuildActionEntry
            buildForTesting = "YES"
            buildForRunning = "YES"
            buildForProfiling = "YES"
            buildForArchiving = "NO"
            buildForAnalyzing = "NO">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "CAFE000000000000000001AA"
               BuildableName = "SFTransitWatch Watch App.app"
               BlueprintName = "SFTransitWatch Watch App"
               ReferencedContainer = "container:SFTransitWatch.xcodeproj">
            </BuildableReference>
         </BuildActionEntry>
         <BuildActionEntry
            buildForTesting = "YES"
            buildForRunning = "NO"
            buildForProfiling = "NO"
            buildForArchiving = "NO"
            buildForAnalyzing = "NO">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "CAFE000000000000000020E0"
               BuildableName = "SFTransitWatch.app"
               BlueprintName = "SFTransitWatch"
               ReferencedContainer = "container:SFTransitWatch.xcodeproj">
            </BuildableReference>
         </BuildActionEntry>
      </BuildActionEntries>
   </BuildAction>
   <TestAction
      buildConfiguration = "Debug"
      selectedDebuggerIdentifier = "Xcode.DebuggerFoundation.Debugger.LLDB"
      selectedLauncherIdentifier = "Xcode.DebuggerFoundation.Launcher.LLDB"
      shouldUseLaunchSchemeArgsEnv = "YES"
      shouldAutocreateTestPlan = "YES">
      <PreActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Reset watch sim before tests"
               scriptText = "# Pre-test sim reset for watchOS snapshot scheme.&#10;#&#10;# DO NOT erase the watch sim. Erasing breaks the watch-iPhone sim pairing,&#10;# which causes &quot;Unknown application display identifier&quot; on the clone xcodebuild&#10;# creates for parallel testing. The original must stay intact so its clone&#10;# inherits a valid pairing.&#10;#&#10;# We DO delete stale clones from previous runs so xcodebuild creates a fresh&#10;# one each time (stale clones can have an outdated xctrunner registry).&#10;#&#10;# If the error persists even with this, run bin/run-watch-snapshot-tests.sh&#10;# which also wipes DerivedData before invoking xcodebuild.&#10;#&#10;# Logs: /tmp/sftransit-preaction.log&#10;LOG=/tmp/sftransit-preaction.log&#10;echo &quot;[$(date)] sftransit snapshot pre-action firing&quot; &gt;&gt; &quot;$LOG&quot;&#10;&#10;/usr/bin/xcrun simctl shutdown all &gt;&gt; &quot;$LOG&quot; 2&gt;&amp;1 || true&#10;&#10;# Delete stale watch sim clones only &#x2014; never erase the original.&#10;/usr/bin/xcrun simctl list devices | grep &quot;Clone.*Apple Watch&quot; \&#10;    | sed &apos;s/.*(\([A-F0-9-]*\)).*/\1/&apos; \&#10;    | while read -r UDID; do&#10;        echo &quot;Deleting clone $UDID&quot; &gt;&gt; &quot;$LOG&quot;&#10;        /usr/bin/xcrun simctl delete &quot;$UDID&quot; &gt;&gt; &quot;$LOG&quot; 2&gt;&amp;1 || true&#10;    done&#10;&#10;echo &quot;[$(date)] sftransit snapshot pre-action done&quot; &gt;&gt; &quot;$LOG&quot;&#10;exit 0&#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "CAFE000000000000000001AA"
                     BuildableName = "SFTransitWatch Watch App.app"
                     BlueprintName = "SFTransitWatch Watch App"
                     ReferencedContainer = "container:SFTransitWatch.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PreActions>
      <Testables>
         <TestableReference
            skipped = "NO"
            parallelizable = "YES">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "84E0253D2FAD714C006B3F47"
               BuildableName = "SFTransitWatchUITests.xctest"
               BlueprintName = "SFTransitWatchUITests"
               ReferencedContainer = "container:SFTransitWatch.xcodeproj">
            </BuildableReference>
         </TestableReference>
      </Testables>
   </TestAction>
   <LaunchAction
