   <TestAction
      buildConfiguration = "Debug"
      selectedDebuggerIdentifier = "Xcode.DebuggerFoundation.Debugger.LLDB"
      selectedLauncherIdentifier = "Xcode.DebuggerFoundation.Launcher.LLDB"
      shouldUseLaunchSchemeArgsEnv = "YES"
      shouldAutocreateTestPlan = "YES">
      <PreActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Reset watch sim + DerivedData before tests"
               scriptText = "# Aggressive pre-test cleanup. Equivalent to:&#10;#   xcrun simctl shutdown all&#10;#   xcrun simctl erase &lt;watch sims&gt;&#10;#   rm -rf ~/Library/Developer/Xcode/DerivedData/SFTransitWatch-*&#10;# Without this, watchOS UI test runs intermittently fail with&#10;# &quot;Unknown application display identifier&quot; until DerivedData is cleared.&#10;# This pre-action makes every test run start from a clean slate; logs&#10;# go to /tmp/sftransit-preaction.log so we can verify the action fires.&#10;LOG=/tmp/sftransit-preaction.log&#10;echo &quot;[$(date)] sftransit watch test pre-action firing&quot; &gt;&gt; &quot;$LOG&quot;&#10;&#10;/usr/bin/xcrun simctl shutdown all &gt;&gt; &quot;$LOG&quot; 2&gt;&amp;1 || true&#10;&#10;for SIM in &quot;Apple Watch Ultra 3 (49mm)&quot; &quot;Apple Watch Ultra 2 (49mm)&quot;; do&#10;    /usr/bin/xcrun simctl erase &quot;$SIM&quot; &gt;&gt; &quot;$LOG&quot; 2&gt;&amp;1 || true&#10;done&#10;&#10;/bin/rm -rf &quot;${HOME}/Library/Developer/Xcode/DerivedData/SFTransitWatch-&quot;* 2&gt;&gt; &quot;$LOG&quot; || true&#10;&#10;echo &quot;[$(date)] sftransit watch test pre-action done&quot; &gt;&gt; &quot;$LOG&quot;&#10;exit 0&#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "CAFE000000000000000001AA"
                     BuildableName = "SFTransitWatch Watch App.app"
                     BlueprintName = "SFTransitWatch Watch App"
                     ReferencedContainer = "container:SFTransitWatch.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PreActions>
      <Testables>
         <TestableReference
            skipped = "NO"
            parallelizable = "YES">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "84C1B1D92F9DE3D700833749"
               BuildableName = "SFTransitWatchTests.xctest"
               BlueprintName = "SFTransitWatchTests"
