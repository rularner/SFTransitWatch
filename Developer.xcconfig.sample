// Copy this file to Developer.xcconfig and set your Apple Developer team ID.
// Your team ID is shown in Xcode under Settings > Accounts, or at
// https://developer.apple.com/account in the Membership section.

DEVELOPMENT_TEAM = YOUR_TEAM_ID

// Worker URLs and tokens are no longer baked into the build. Each device
// pastes a worker bootstrap link (carries both URL and token) into iOS
// Settings, or receives it via a /wt universal link on the watch. See the
// "Worker proxy" section of the README.
